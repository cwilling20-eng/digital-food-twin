    {
      "parameters": {
        "jsCode": "const profile = $('Supabase - Get User Goals').first().json;\nconst meals = $('Supabase - Get Today\\'s Meals').all().map(m => m.json);\n\n// Sum today's nutrition\nconst today = {\n  calories: 0,\n  protein_g: 0,\n  carbs_g: 0,\n  fat_g: 0,\n  fiber_g: 0,\n  sugar_g: 0,\n  sodium_mg: 0,\n  meal_count: meals.length\n};\n\nfor (const meal of meals) {\n  today.calories += meal.estimated_calories || 0;\n  today.protein_g += meal.protein_g || 0;\n  today.carbs_g += meal.carbs_g || 0;\n  today.fat_g += meal.fat_g || 0;\n  today.fiber_g += meal.fiber_g || 0;\n  today.sugar_g += meal.sugar_g || 0;\n  today.sodium_mg += meal.sodium_mg || 0;\n}\n\n// Goals with defaults\nconst goals = {\n  calorie_goal: profile.calorie_goal || 2000,\n  protein_goal: profile.protein_goal || 150,\n  carbs_goal: profile.carbs_goal || 200,\n  fat_goal: profile.fat_goal || 65\n};\n\n// Calculate remaining\nconst remaining = {\n  calories: goals.calorie_goal - today.calories,\n  protein_g: goals.protein_goal - today.protein_g,\n  carbs_g: goals.carbs_goal - today.carbs_g,\n  fat_g: goals.fat_goal - today.fat_g\n};\n\n// Body metrics\nconst body = {\n  current_weight: profile.current_weight || null,\n  goal_weight: profile.goal_weight || null,\n  starting_weight: profile.starting_weight || null\n};\n\nreturn {\n  json: {\n    goals,\n    today,\n    remaining,\n    body,\n    meals: meals.map(m => ({\n      name: m.meal_name,\n      calories: m.estimated_calories,\n      meal_type: m.meal_type,\n      time: m.created_at\n    }))\n  }\n};"
      },
